# ──────────────────────────────────────────────────────────────────────────
# .env.example — Environment Variables for Emotional Weight Backend
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# NEVER commit .env — it is listed in .gitignore.
#
# For HuggingFace Spaces deployment, set these as Space secrets in:
#   Space → Settings → Repository secrets
# ──────────────────────────────────────────────────────────────────────────

# Required — HuggingFace token to download the facebook/tribev2 model weights.
# Generate at: https://huggingface.co/settings/tokens
# The token needs read access to the facebook/tribev2 repo.
HF_TOKEN=hf_your_token_here

# Optional — override where HuggingFace caches model weights (default: ~/.cache/huggingface)
# In Docker / HF Spaces this is set to /app/cache via ENV in the Dockerfile.
# HF_HOME=/path/to/cache
